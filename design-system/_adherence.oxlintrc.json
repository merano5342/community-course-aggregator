{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Space Mono|Noto Sans TC))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Space Mono, Noto Sans TC."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppSidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:activeItem|onNavigate|key|ref|className|style|children)$/]",
        "message": "<AppSidebar> doesn't accept that prop. Declared props: activeItem, onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppSidebar'] > JSXAttribute[name.name='activeItem'] > Literal[value!=/^(?:browse|courses|saved|stats)$/]",
        "message": "<AppSidebar> activeItem must be one of 'browse' | 'courses' | 'saved' | 'stats'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent|dark|neutral|success|warning|error)$/]",
        "message": "<Badge> variant must be one of 'accent' | 'dark' | 'neutral' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|pill|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, pill, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|dark|ghost|accent|surface)$/]",
        "message": "<Button> variant must be one of 'primary' | 'dark' | 'ghost' | 'accent' | 'surface'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|radius|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, radius, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|dark|accent|white|surface)$/]",
        "message": "<Card> variant must be one of 'light' | 'dark' | 'accent' | 'white' | 'surface'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|type|prefix|suffix|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: placeholder, value, onChange, type, prefix, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|deltaLabel|variant|pill|accentBar|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, delta, deltaLabel, variant, pill, accentBar, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|dark|accent)$/]",
        "message": "<StatCard> variant must be one of 'light' | 'dark' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|size|removable|onRemove|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, color, size, removable, onRemove."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:default|accent|dark)$/]",
        "message": "<Tag> color must be one of 'default' | 'accent' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
